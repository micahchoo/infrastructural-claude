# Credentials
.credentials.json
.credentials/

# Plugin caches (large, auto-downloaded)
plugins/cache/
plugins/marketplaces/

# Session data
projects/*/
!projects/*/memory/

# Debug/runtime logs
context-mode/sessionstart-debug.log
context-mode/precompact-debug.log
logs/anti-pattern-scan.log

# Autoresearch artifacts
autoresearch/__pycache__/
