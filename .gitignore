autoresearch/runs/
autoresearch/tasks.json
autoresearch/variants/*/

# Backups (generated at runtime)
backups/

# File history (session edit tracking)
file-history/

# Runtime data
tasks/
paste-cache/
teams/
shell-snapshots/
sessions/

# Telemetry/history
telemetry/
history.jsonl
stats-cache.json

# Stale backups
settings.json.orig
settings.json.bak
cache/

# Temp/cache
.cache/
*.pyc
debug/
tmp/
mcp-needs-auth-cache.json
